# ClickUp personal API token (Settings → Apps → API Token)
CLICKUP_TOKEN=pk_xxxxxxxxxxxxxxxxxxxx

# Comma-separated ClickUp workspace ID (Settings → Workspace → ID)
CLICKUP_WORKSPACE_ID=your_workspace_id

# Comma-separated ClickUp folder IDs containing routing docs
# Find these in the ClickUp URL when you're inside a folder: /2/<workspace>/<space>/<folder>
CLICKUP_DOC_FOLDER_IDS=folder_id_1,folder_id_2
